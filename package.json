{
  "name": "marlin",
  "version": "1.0.0",
  "description": "REST API wrapper for Projects.co.id — automate deposits, auth, and payment confirmation via browser automation.",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc",
    "serve": "node dist/index.js",
    "test": "npm run test:manager",
    "test:manager": "tsx scripts/test-manager.ts",
    "test:auth": "tsx scripts/test-auth.ts"
  },
  "keywords": [
    "projects.co.id",
    "deposit",
    "api",
    "marlin",
    "freelance"
  ],
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "playwright": "^1.52.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
