PORT=3100
SESSION_TTL_MS=1800000

# Browser mode: auto | local | cdp | manager
BROWSER_MODE=local

# Local CloakBrowser Chromium (auto-detected path after `npx cloakbrowser install` or set manually)
# macOS:  ~/Library/Application Support/cloakbrowser/chromium-*/chrome
# Linux:  ~/.cloakbrowser/chromium-*/chrome
CHROMIUM_PATH=

# Remote CDP (cloakserve) — base URL only, no /json/version
# CDP_URL=https://your-cloakbrowser.example.com

# CloakBrowser Manager — one profile per Marlin session
# MANAGER_URL=http://localhost:8080
# MANAGER_AUTH_TOKEN=
# MANAGER_PROXY=http://user:pass@proxy:port
# MANAGER_GEOIP=true

# Upstash Redis — session metadata across restarts / multiple instances (required on Vercel)
# UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
# UPSTASH_REDIS_REST_TOKEN=

# --- Vercel deployment (set in Vercel dashboard) ---
# BROWSER_MODE=manager
# MANAGER_URL=https://your-manager.koyeb.app
# MANAGER_PROXY=http://user:pass@proxy:port
# MANAGER_GEOIP=true
# UPSTASH_REDIS_REST_URL=...
# UPSTASH_REDIS_REST_TOKEN=...
